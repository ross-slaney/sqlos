{
  "SqlOS": {
    "Issuer": "http://localhost:5080/sqlos/auth"
  },
  "TodoSample": {
    "PublicOrigin": "http://localhost:5080",
    "Resource": "http://localhost:5080/api/todos",
    "HostedClientId": "todo-web",
    "HostedClientName": "Todo Web App",
    "EnableHeadless": false,
    "EnableDcr": false,
    "LocalClientId": "todo-local",
    "LocalRedirectUri": "http://localhost:3100/oauth/callback",
    "PortableClientPath": "/clients/portable-client.json",
    "PortableClientName": "SqlOS Todo Portable Client",
    "PortableClientRedirectUri": "https://portable.todo.example.com/auth/callback",
    "PortableClientUri": "https://portable.todo.example.com",
    "PortableSoftwareId": "io.sqlos.todo",
    "PortableSoftwareVersion": "2026.1",
    "AllowedScopes": [
      "openid",
      "profile",
      "email",
      "offline_access",
      "todos.read",
      "todos.write"
    ]
  }
}
