    "CallbackUrl": "http://localhost:3000/auth/callback",
    "ClientId": "example-web"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
