{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "SqlOS": {
    "AuthMode": "Hosted",
    "Issuer": "http://localhost:5062/sqlos/auth",
    "HeadlessFrontendUrl": "http://localhost:3000",
    "Dashboard": {
      "AuthMode": "Password",
      "Password": "your-strong-password",
